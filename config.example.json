        "enabled": false,
        "smtp_host": "",
        "smtp_port": 587,
        "username": "",
        "password": "",
        "to": ""
      }
    },
    "quiet_hours": {
      "enabled": false,
      "start": "23:00",
      "end": "07:00",
      "timezone": "auto",
      "hold_and_send": true
    }
