{
  "search": {
    "location_mode": "manual",
    "locations": [
      {
        "name": "城市名称",
        "city": "City",
        "country": "Country",
        "location": "City, Country",
        "enabled": true,
        "radius_km": 30,
        "keywords": ["关键词1", "Keyword2"],
        "keyword_aliases": {},
        "user_prompt": "描述你想找的职位类型和不感兴趣的方向",
        "blacklist": {
          "companies": [],
          "keywords": []
        }
      }
    ],
    "hours_old": 24,
    "interval_minutes": 60,
