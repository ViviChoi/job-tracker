      "max_attempts": 3,
      "retry_interval_minutes": 5,
      "pause_on_failure_minutes": 60
    },
    "blacklist": {
      "companies": [],
      "keywords": []
    }
  },
  "matching": {
    "mode": "ai",
    "min_score": 70,
